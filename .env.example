# Copy this file to .env (same folder) and fill in your own Supabase project's values.
# Find both by clicking "Connect" at the top of your Supabase project dashboard,
# or under Project Settings > API Keys (see README.md step 1 for details).
# VITE_SUPABASE_ANON_KEY can be either the "Publishable key" (sb_publishable_...)
# or the older "anon / public" key (eyJ...) -- either works.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here
